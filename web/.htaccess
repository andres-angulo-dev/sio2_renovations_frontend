<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Force www (canonical domain)
  RewriteCond %{HTTP_HOST} ^sio2renovations\.com$ [NC]
  RewriteRule ^ https://www.sio2renovations.com%{REQUEST_URI} [R=301,L]

  # Flutter SPA routing — redirect all unknown paths to index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # Cache-Control — stratégie par type de fichier
  # main.dart.js : 1 an + immutable (Flutter génère un nouveau hash à chaque build,
  # l'ancien fichier n'est jamais réutilisé — cache long sans risque)
  <FilesMatch "^main\.dart\.js$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Assets statiques (images, polices) : 30 jours
  <FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico|ttf|otf|woff|woff2)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # Fichiers de contrôle Flutter : jamais en cache long
  # Ces fichiers pilotent le chargement — un cache long bloquerait les mises à jour
  <FilesMatch "(index\.html|flutter_bootstrap\.js|manifest\.json|flutter_service_worker\.js|flutter\.js)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# Compression gzip (améliore le transfert de main.dart.js et des assets texte)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>
